.nf
.Ft const char *
.Fo libvmdk_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libvmdk_get_access_flags_read
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libvmdk_get_codepage
